# Copy this file to .streamlit/secrets.toml and fill in your keys.
# On Streamlit Cloud: Settings → Secrets → paste contents here.
# Locally: save as .streamlit/secrets.toml (already in .gitignore).

# ── Groq API ──────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY = "gsk_YOUR_KEY_HERE"

# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Then run migrations/001_initial_schema.sql in the SQL editor.
SUPABASE_URL = "https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_KEY = "eyJ_YOUR_ANON_KEY_HERE"