# Rename this file to secrets.toml and fill in your keys.
# On Streamlit Cloud: Settings → Secrets → paste contents here.
# Locally: save as .streamlit/secrets.toml (already in .gitignore).

# ── Groq API (required for LLM categorisation panel) ─────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY = "gsk_YOUR_KEY_HERE"
